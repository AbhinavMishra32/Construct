{
  "name": "@construct/app",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "main": "dist/main.cjs",
  "scripts": {
    "dev": "concurrently -k -n renderer,main,electron \"pnpm dev:renderer\" \"pnpm dev:main\" \"pnpm dev:electron\"",
    "dev:renderer": "vite",
    "dev:main": "tsup --watch",
    "dev:electron": "wait-on tcp:5173 file:dist/main.cjs file:dist/preload.cjs && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron .",
    "build": "pnpm build:main && pnpm build:renderer",
    "build:main": "tsup",
    "build:renderer": "vite build",
    "typecheck": "tsc --noEmit",
    "test": "node -e \"console.log('App tests are not implemented yet.')\""
  },
  "dependencies": {
    "@monaco-editor/react": "^4.7.0",
    "framer-motion": "^12.4.2",
    "monaco-editor": "^0.52.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/react": "^19.0.12",
    "@types/react-dom": "^19.0.4",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "electron": "^35.0.1",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "tsup": "^8.4.0",
    "typescript": "^5.8.2",
    "vite": "^6.2.2",
    "wait-on": "^8.0.3"
  }
}
